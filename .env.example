# ═══════════════════════════════════════════════════════════════
# Wolf Marketplace — Environment Variables
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to git — it's in .gitignore.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Push Notifications (VAPID) ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# Also set VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY as Supabase Edge Function secrets
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── PayChangu (Mobile Money Payments) ─────────────────────────
# Dashboard → https://paychangu.com → API Keys
VITE_PAYCHANGU_SECRET_KEY=your-paychangu-secret-key-here
VITE_PAYCHANGU_PUBLIC_KEY=your-paychangu-public-key-here

# ── App URL (used in sitemap + email links) ───────────────────
VITE_APP_URL=https://wolfmarketplace.app

# ── Supabase Edge Function Secrets (set via CLI, not here) ────
# supabase secrets set VAPID_PUBLIC_KEY=...
# supabase secrets set VAPID_PRIVATE_KEY=...
# supabase secrets set RESEND_API_KEY=re_...        (email digests)
# supabase secrets set APP_URL=https://wolfmarketplace.app
# supabase secrets set PAYCHANGU_SECRET_KEY=...
